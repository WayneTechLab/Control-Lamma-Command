{
  "name": "webapp-stack-g1",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "WebApp Stack G One Point Zero — TS + React + Vite + Tailwind + Firebase starter template.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b --noCheck && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "emulators": "firebase emulators:start",
    "emulators:export": "firebase emulators:start --export-on-exit=.emulator-data --import=.emulator-data",
    "deploy": "bash .SYSTEMX/scripts/deploy.sh",
    "ci:lint": "eslint . --max-warnings=0",
    "ci:typecheck": "tsc --noEmit -p tsconfig.json",
    "ci:build": "vite build"
  },
  "dependencies": {
    "firebase": "^12.14.0",
    "lucide-react": "^0.484.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.19",
    "firebase-tools": "^14.2.0",
    "globals": "^17.1.0",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^7.3.3"
  }
}
